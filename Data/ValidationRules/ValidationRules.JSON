{
    "ValidationRules": [
        {
            "AssociatedSource": "MERCADOLIBRE",
            "AllowedSubDomains": ["www", "listado", "articulo"],
            "AllowedDomain": ["mercadolibre.cl"],
            "AllowedPaths": [
                "^/$",
                "^/p/",
                "^/MLC-",
                "^/MLC"
            ],
            "FollowPagination": true,
            "MaxDepthOverride": 5
        },
        {
            "AssociatedSource": "FALABELLA",
            "AllowedSubDomains": ["www"],
            "AllowedDomain": ["falabella.com"],
            "AllowedPaths": [
                "^/falabella-cl/search",
                "^/falabella-cl/category/",
                "^/falabella-cl/product/"
            ],
            "FollowPagination": true,
            "MaxDepthOverride": 3
        },
        {
            "AssociatedSource": "PARIS",
            "AllowedSubDomains": ["www"],
            "AllowedDomain": ["paris.cl"],
            "AllowedPaths": [
                "^/search$",
                "^/.+\\.html$",
                "^/(?!search$|cart|checkout|login|mi-cuenta)[^?]+/$"
            ],
            "FollowPagination": true,
            "MaxDepthOverride": 3
        },
        {
            "AssociatedSource": "RIPLEY",
            "AllowedSubDomains": ["simple"],
            "AllowedDomain": ["ripley.cl"],
            "AllowedPaths": [
                "^/search/",
                "^/product/",
                "^/[a-z0-9-]+$"
            ],
            "FollowPagination": true,
            "MaxDepthOverride": 3
        }
    ]
}

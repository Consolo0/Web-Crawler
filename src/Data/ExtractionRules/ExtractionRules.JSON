{
    "ExtractionRules": [
        {
            "AssociatedSource": "MERCADOLIBRE",
            "ProductTitle": { 
                "1": {
                    "Selector": "name",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": "h1, .ui-pdp-title",
                    "Attribute": "text"
                }
            },
            "Price": {
                "1": {
                    "Selector": "offers",
                    "SubSelector": "price",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": ".ui-pdp-price__second-line, [data-test='price']",
                    "Attribute": "text"
                }
            },
            "Stock": {
                "1": {
                    "Selector": "offers",
                    "SubSelector": "availability",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": "[class*='availability'], .stock",
                    "Attribute": "text"
                }
            },
            "Rating": {
                "1": {
                    "Selector": "aggregateRating",
                    "SubSelector": "ratingValue",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": ".ui-pdp-review__rating, [data-test='rating']",
                    "Attribute": "text"
                }
            },
            "Votes": {
                "1": {
                    "Selector": "aggregateRating",
                    "SubSelector": "ratingCount",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": ".ui-pdp-review__amount, [data-test='reviews']",
                    "Attribute": "text"
                }
            }
        },
        {
            "AssociatedSource": "FALABELLA",
            "ProductTitle": {
                "1": {
                    "Selector": "name",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": "h1",
                    "Attribute": "text"
                }
            },
            "Price": {
                "1": {
                    "Selector": "offers",
                    "SubSelector": "price",
                    "Attribute": "json",
                    "Comment": "Extracts minimum price from offers array (promotional price)"
                },
                "2": {
                    "Selector": "span.copy, div[class*='prices'] span",
                    "Attribute": "text",
                    "Comment": "Fallback to HTML price elements"
                }
            },
            "Stock": {
                "1": {
                    "Selector": "offers",
                    "SubSelector": "availability",
                    "Attribute": "json",
                    "Comment": "Checks if ANY offer has InStock availability"
                },
                "2": {
                    "Selector": "[class*='stock'], [class*='available'], .content",
                    "Attribute": "text",
                    "Comment": "Fallback: checks for 'agotado' or 'sin stock' in text"
                }
            },
            "Rating": {
                "1": {
                    "Selector": ".styles-module_rating__VKBa1, [class*='rating']:not([class*='container'])",
                    "Attribute": "text",
                    "Comment": "Falabella doesn't include aggregateRating in JSON-LD, must use HTML"
                },
                "2": {
                    "Selector": ".rr-rating-stars, [data-test='rating']",
                    "Attribute": "text"
                }
            },
            "Votes": {
                "1": {
                    "Selector": ".styles-module_reviewCount__3GFJ7, [class*='reviewCount']",
                    "Attribute": "text",
                    "Comment": "Extract review count from HTML like '(6)' or '(27)'"
                },
                "2": {
                    "Selector": "[data-test='reviews'], .reviews",
                    "Attribute": "text"
                }
            }
        },
        {
            "AssociatedSource": "PARIS",
            "ProductTitle": {
                "1": {
                    "Selector": "name",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": "h1, [data-test='product-title']",
                    "Attribute": "text"
                }
            },
            "Price": {
                "1": {
                    "Selector": "offers",
                    "SubSelector": "price",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": "[data-test='price'], .price, [class*='price']",
                    "Attribute": "text"
                }
            },
            "Stock": {
                "1": {
                    "Selector": "offers",
                    "SubSelector": "availability",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": "[class*='availability'], [data-test='availability']",
                    "Attribute": "text"
                }
            },
            "Rating": {
                "1" : {
                    "Selector": "aggregateRating",
                    "SubSelector": "ratingValue",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": "[data-test='rating'], .rating, [class*='rating']",
                    "Attribute": "text"
                }
            },
            "Votes": {
                "1": {
                    "Selector": "aggregateRating",
                    "SubSelector": "ratingCount",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": "[data-test='reviews'], .reviews, [class*='reviews']",
                    "Attribute": "text"
                }
            }
        },
        {
            "AssociatedSource": "RIPLEY",
            "ProductTitle": {
                "1": {
                    "Selector": "section.product-header h1",
                    "Attribute": "text"
                }
            },
            "Price": {
                "1": {
                    "Selector": "dt.product-price",
                    "Attribute": "text"
                }
            },
            "Stock": {
                "1": {
                    "Selector": "div.stock-info span.available-stock",
                    "Attribute": "text"
                }
            },
            "Rating": {
                "1": {
                    "Selector": "span.pr-reco-value",
                    "Attribute": "text"
                }
            },
            "Votes": {
                "1": {
                    "Selector": "span.pr-reco-count",
                    "Attribute": "text"
                }
            }
        },
        {
            "AssociatedSource": "LIDER",
            "ProductTitle": {
                "1": {
                    "Selector": "h1#main-title[itemprop='name']",
                    "Attribute": "text"
                }
            },
            "Price": {
                "1": {
                    "Selector": "span[itemprop='price'][data-fs-element='price']",
                    "Attribute": "text"
                }
            },
            "Stock": {
                "1": {
                    "Selector": "button[data-fs-element='add-to-cart'], button:contains('Agregar')",
                    "Attribute": "existence"
                }
            },
            "Rating": {
                "1": {
                    "Selector": "span.rating-number",
                    "Attribute": "text"
                }
            },
            "Votes": {
                "1": {
                    "Selector": "span.total-reviews",
                    "Attribute": "text"
                }
            }
        }
    ]
}
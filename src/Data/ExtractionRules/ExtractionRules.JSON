{
    "ExtractionRules": [
        {
            "AssociatedSource": "MERCADOLIBRE",
            "ProductTitle": { 
                "1": {
                    "Selector": "name",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": "h1, .ui-pdp-title",
                    "Attribute": "text"
                }
            },
            "Price": {
                "1": {
                    "Selector": "offers",
                    "SubSelector": "price",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": ".ui-pdp-price__second-line, [data-test='price']",
                    "Attribute": "text"
                }
            },
            "Stock": {
                "1": {
                    "Selector": "offers",
                    "SubSelector": "availability",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": "[class*='availability'], .stock",
                    "Attribute": "text"
                }
            },
            "Rating": {
                "1": {
                    "Selector": "aggregateRating",
                    "SubSelector": "ratingValue",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": ".ui-pdp-review__rating, [data-test='rating']",
                    "Attribute": "text"
                }
            },
            "Votes": {
                "1": {
                    "Selector": "aggregateRating",
                    "SubSelector": "ratingCount",
                    "Attribute": "json"
                },
                "2": {
                    "Selector": ".ui-pdp-review__amount, [data-test='reviews']",
                    "Attribute": "text"
                }
            }
        },
        {
            "AssociatedSource": "FALABELLA",
            "ProductTitle": {
                "1": {
                    "Selector": "h1",
                    "Attribute": "text"
                }
            },
            "Price": {
                "1": {
                    "Selector": "[data-test='price'], .price, .product-price, [class*='price']",
                    "Attribute": "text"
                }
            },
            "Stock": {
                "1": {
                    "Selector": "[data-test='availability'], .availability, [class*='stock']",
                    "Attribute": "text"
                }
            },
            "Rating": {
                "1": {
                    "Selector": "[data-test='rating'], .rating, [class*='rating']",
                    "Attribute": "text"
                }
            },
            "Votes": {
                "1": {
                    "Selector": "[data-test='reviews'], .reviews, [class*='reviews']",
                    "Attribute": "text"
                }
            }
        },
        {
